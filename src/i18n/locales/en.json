    "whoWeAre": {
      "title": "Who We Are?",
      "content": "At jyoh.in, we are transforming the way India handles legal paperwork.",
      "detail1": "Our platform enables users to create affidavits, rental agreements, declarations, and e-stamp papers online — quickly and securely.",
      "detail2": "With a tech-first approach, we remove legal complexity, offering simplified, verified, and ready-to-use documents for individuals, businesses, and everyday needs — all at your fingertips."
    },
    "mission": {
      "title": "Our Mission",
      "content": "At jyoh.in, our mission is to bridge the gap between the average citizen and the often intimidating world of legal documentation.",
      "detail1": "We aim to empower individuals, entrepreneurs, tenants, and businesses by making legally valid documents accessible through a fast, transparent, and technology-driven platform.",
      "detail2": "Our mission is to democratize legal aid, giving everyone the confidence to handle important agreements with ease.",
      "detail3": "We envision a future where legal compliance is a click away, making life simpler for millions of users."
    },
    "offer": {
      "title": "What We Offer",
      "subtitle": "A Legal Ecosystem Built for You",
      "content": "From essential legal drafts to complex registrations, we cover it all.",
      "feature1": "Instantly generate legally valid drafts",
      "feature2": "Apply and receive verified e-stamp papers",
      "feature3": "Access localized documents tailored to Indian laws",
      "feature4": "Download, print, or share your documents instantly",
