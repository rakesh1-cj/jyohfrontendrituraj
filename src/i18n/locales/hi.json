  "about": {
    "hero": {
      "title": "आपके कानूनी दस्तावेज़।",
      "subtitle": "सरलीकृत।",
      "description": "हमारे तकनीक-प्रथम प्लेटफ़ॉर्म के साथ कानूनी कागजी कार्रवाई को संभालने के तरीके को बदलें। कहीं से भी कानूनी रूप से अनुपालन करने वाले दस्तावेज़ बनाएं, डाउनलोड करें और उपयोग करें - आत्मविश्वास से और स्वतंत्र रूप से।"
    },
    "whoWeAre": {
      "title": "हम कौन हैं?",
      "content": "jyoh.in पर, हम भारत के कानूनी कागजी कार्रवाई को संभालने के तरीके को बदल रहे हैं।",
      "detail1": "हमारा प्लेटफ़ॉर्म उपयोगकर्ताओं को हलफनामा, किराया समझौता, घोषणा पत्र और ई-स्टांप पेपर ऑनलाइन - जल्दी और सुरक्षित रूप से बनाने में सक्षम बनाता है।",
      "detail2": "तकनीक-प्रथम दृष्टिकोण के साथ, हम कानूनी जटिलता को हटाते हैं, व्यक्तियों, व्यवसायों और रोजमर्रा की जरूरतों के लिए सरलीकृत, सत्यापित और उपयोग के लिए तैयार दस्तावेज़ पेश करते हैं - सब कुछ आपकी उंगलियों पर।"
    },
    "mission": {
